# ============================================================
# SECRETS & CREDENTIALS — never commit these
# ============================================================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/
# _inbox: ship folder structure, ignore all dropped content
_inbox/*
!_inbox/README.md
!_inbox/private/
!_inbox/images/
!_inbox/files/
_inbox/private/*
!_inbox/private/.gitkeep
_inbox/images/*
!_inbox/images/.gitkeep
_inbox/files/*
!_inbox/files/.gitkeep
# _outbox is intentionally tracked (snippet staging for cross-project harvest);
# only _outbox/private/ contents are ignored. Asymmetric with _inbox/ on purpose —
# see _outbox/README.md and .claude/rules/outbox-capture.md.
_outbox/private/*
!_outbox/private/.gitkeep

# ============================================================
# OS FILES
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
ehthumbs.db

# ============================================================
# EDITOR & IDE
# ============================================================
.vscode/launch.json
.vscode/tasks.json
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*.swo
*~

# ============================================================
# BUILD OUTPUT
# ============================================================
bin/
obj/
dist/
build/
out/
target/
*.exe.bak

# ============================================================
# LOGS & TEMP
# ============================================================
*.log
logs/
*.tmp
*.temp
*.bak
~$*
npm-debug.log*

# ============================================================
# DEPENDENCIES
# ============================================================
node_modules/
packages/
.pnp
.pnp.js

# ============================================================
# CLAUDE CODE — machine-specific / personal files stay local
# ============================================================
.claude/settings.local.json
.claude/harvest-queue.md
CLAUDE.local.md
