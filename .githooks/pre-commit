#!/usr/bin/env bash
# Pre-commit hook: detect common secret patterns before they reach the repo.
# Install once per machine: git config core.hooksPath .githooks
set -euo pipefail

# Patterns that indicate a potential hardcoded secret.
# Each entry is a case-insensitive extended regex matched against added lines.
PATTERNS=(
  'AKIA[0-9A-Z]{16}'                              # AWS access key ID
  'sk-[a-zA-Z0-9]{32,}'                           # OpenAI / Anthropic key prefix
  'ghp_[a-zA-Z0-9]{36}'                           # GitHub classic PAT
  'github_pat_[a-zA-Z0-9_]{82}'                   # GitHub fine-grained PAT
  'xox[baprs]-[a-zA-Z0-9-]+'                      # Slack token
  'AIza[0-9A-Za-z_-]{35}'                         # Google API key
  'eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\.'          # JWT (header.payload.)
  'password\s*=\s*["\x27][^"\x27]{8,}'            # Hardcoded password assignment
  'api[_-]?key\s*=\s*["\x27][^"\x27]{8,}'        # Generic API key assignment
  'secret\s*=\s*["\x27][^"\x27]{8,}'             # Generic secret assignment
  '-----BEGIN[[:space:]]+(RSA[[:space:]]+|EC[[:space:]]+|OPENSSH[[:space:]]+|DSA[[:space:]]+)?PRIVATE[[:space:]]+KEY' # PEM private key material
  'postgres://[^[:space:]@]+:[^[:space:]@]+@'     # Postgres connection string with credentials
  'mysql://[^[:space:]@]+:[^[:space:]@]+@'        # MySQL connection string with credentials
  'mongodb(\+srv)?://[^[:space:]@]+:[^[:space:]@]+@' # MongoDB connection string with credentials
)

STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ -z "$STAGED" ]; then
  exit 0
fi

FOUND=0
DIFF=$(git diff --cached -U0 | grep '^+' | grep -v '^+++' || true)

if [ -z "$DIFF" ]; then
  exit 0
fi

for pattern in "${PATTERNS[@]}"; do
  matches=$(echo "$DIFF" | grep -iE "$pattern" || true)
  if [ -n "$matches" ]; then
    echo ""
    echo "BLOCKED: Potential secret detected (pattern: $pattern)"
    echo "$matches"
    FOUND=1
  fi
done

if [ "$FOUND" -ne 0 ]; then
  echo ""
  echo "Commit blocked. Review the flagged lines above."
  echo "If this is a confirmed false positive, bypass with:"
  echo "  git commit --no-verify"
  echo "Only bypass when you are certain no real secret is present."
  exit 1
fi
