root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown: preserve trailing spaces (two spaces = hard line break)
[*.md]
trim_trailing_whitespace = false

# Windows scripts must use CRLF
[*.{ps1,psm1,psd1,bat,cmd}]
end_of_line = crlf

# Makefiles require tabs
[Makefile]
indent_style = tab
