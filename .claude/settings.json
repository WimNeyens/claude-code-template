{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm run *)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm test)",
      "Bash(npm ci)",
      "Bash(node --version)",
      "Bash(pip install *)",
      "Bash(pip install)",
      "Bash(pip freeze)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pytest)",
      "Bash(pytest *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push --no-verify*)",
      "Bash(git push * --no-verify*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase -i*)",
      "Bash(rm -rf *)"
    ]
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "project_settings",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Project settings change blocked. Edit .claude/settings.json manually outside of a session.' && exit 2"
          }
        ]
      }
    ]
  }
}
